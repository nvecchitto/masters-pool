<% content_for :title, "Draft — #{@pool.name}" %>

<%# Subscribe to live draft updates broadcast by DraftController#broadcast_draft_update %>
<%= turbo_stream_from "pool_#{@pool.id}_draft" %>

<%# Embed current user's participant ID for client-side turn enforcement %>
<meta name="current-participant-id" content="<%= current_user&.id %>">

<div class="min-h-screen bg-gray-950 text-gray-100" id="draft-page">

  <%# ── Header ─────────────────────────────────────────────────────────── %>
  <header class="bg-green-900 border-b border-green-700 px-6 py-4 flex items-center justify-between">
    <h1 class="text-xl font-bold text-white">
      <%= @pool.name %> &mdash; Snake Draft
    </h1>
    <%= link_to "← Dashboard",
          pool_dashboard_path(@pool),
          class: "text-sm text-green-300 hover:text-white transition-colors" %>
  </header>

  <div class="max-w-7xl mx-auto px-4 py-6 flex flex-col lg:flex-row gap-6">

    <%# ── LEFT: Current Picker + Available Golfers ─────────────────────── %>
    <div class="lg:w-3/5 space-y-4">

      <%# Current Picker Card — replaced by Turbo Stream on each pick %>
      <div id="current_picker">
        <%= render "current_picker", pool: @pool, current_team: @current_team %>
      </div>

      <%# Login prompt if not logged in and draft is still going %>
      <% if !logged_in? && !@pool.draft_complete? %>
        <div class="bg-yellow-900/30 border border-yellow-700 rounded-lg px-5 py-4 flex items-center justify-between gap-4">
          <p class="text-yellow-300 text-sm">Log in to pick when it's your turn.</p>
          <div class="flex gap-3 shrink-0">
            <%= link_to "Log in", login_path,
                  class: "text-xs bg-green-700 hover:bg-green-600 text-white font-medium px-3 py-1.5 rounded transition-colors" %>
            <%= link_to "Sign up", sign_up_path,
                  class: "text-xs text-green-400 hover:text-green-300 font-medium" %>
          </div>
        </div>
      <% end %>

      <%# Available Golfers — replaced by Turbo Stream on each pick %>
      <div id="available_golfers">
        <%= render "available_golfers", pool: @pool, golfers: @available %>
      </div>
    </div>

    <%# ── RIGHT: Draft Board ──────────────────────────────────────────── %>
    <div class="lg:w-2/5">
      <h2 class="text-base font-semibold text-gray-300 mb-3">Draft Board</h2>
      <div id="draft_board">
        <%= render "draft_board", teams: @teams %>
      </div>
    </div>

  </div>
</div>

<%# ── Heartbeat: keep last_active_at fresh while on the draft page ─────── %>
<% if logged_in? %>
<script>
(function() {
  var url = "<%= draft_heartbeat_path(@pool) %>";
  var token = document.querySelector("meta[name='csrf-token']")?.content;
  function ping() {
    fetch(url, { method: "POST", headers: { "X-CSRF-Token": token } });
  }
  ping(); // immediately on load
  setInterval(ping, 60000); // then every 60 seconds
})();
</script>
<% end %>

<%# ── Turn-based pick enforcement ─────────────────────────────────────── %>
<script>
(function() {
  var myId = (document.querySelector("meta[name='current-participant-id']") || {}).content || "";

  function updatePickButtons() {
    var pickingEl = document.querySelector("[data-picking-participant-id]");
    var pickingId = pickingEl ? pickingEl.dataset.pickingParticipantId : "";
    var isMyTurn = myId.length > 0 && myId === pickingId;

    document.querySelectorAll(".pick-btn").forEach(function(btn) {
      btn.disabled = !isMyTurn;
    });
  }

  // Run on load
  updatePickButtons();

  // Re-run after any Turbo Stream updates the current_picker or available_golfers
  var observer = new MutationObserver(updatePickButtons);
  var draftPage = document.getElementById("draft-page");
  if (draftPage) {
    observer.observe(draftPage, { childList: true, subtree: true });
  }
})();
</script>
