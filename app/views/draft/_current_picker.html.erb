<%# locals: (pool:, current_team:) %>
<% if pool.draft_complete? || current_team.nil? %>
  <div class="bg-green-900/40 border border-green-700 rounded-lg px-5 py-4">
    <p class="text-green-300 font-semibold text-lg">Draft Complete!</p>
    <p class="text-green-400 text-sm mt-1">All <%= pool.golfers_per_team %> rounds have been picked.</p>
  </div>
<% else %>
  <div class="bg-gray-900 border border-<%= current_team.badge_color.split('-').second %>-600 rounded-lg px-5 py-4"
       data-picking-participant-id="<%= current_team.participant_id %>">
    <p class="text-xs text-gray-400 uppercase tracking-wider mb-1">
      Pick #<%= pool.current_pick_number %> of <%= pool.teams.size * pool.golfers_per_team %>
    </p>
    <div class="flex items-center justify-between">
      <div>
        <p class="text-lg font-bold text-white">
          <span class="inline-block w-3 h-3 rounded-full <%= current_team.badge_color %> mr-2"></span>
          <%= current_team.name %> is on the clock
        </p>
        <p class="text-sm text-gray-400 mt-0.5"><%= current_team.participant.name %></p>
      </div>
      <% if !current_team.participant.registered? %>
        <span class="text-xs bg-yellow-900/50 border border-yellow-700 text-yellow-400 px-3 py-1 rounded-full">
          Not logged in
        </span>
      <% end %>
    </div>
  </div>
<% end %>
