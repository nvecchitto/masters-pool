<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Rails 8 Template" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>

  <body>
    <div class="bg-gray-900 border-b border-gray-800 px-4 py-2 flex items-center justify-between text-sm">
      <%= link_to "Masters Pool", root_path,
            class: "text-green-400 hover:text-green-300 font-semibold transition-colors" %>
      <% if logged_in? %>
        <div class="flex items-center gap-4">
          <span class="text-gray-400 hidden sm:inline">Logged in as <span class="text-white font-medium"><%= current_user.name %></span></span>
          <span class="text-gray-400 sm:hidden text-xs font-medium text-white"><%= current_user.name %></span>
          <%= button_to "Log out", logout_path, method: :delete,
                class: "text-gray-400 hover:text-red-400 transition-colors text-xs font-medium" %>
        </div>
      <% else %>
        <div class="flex items-center gap-3">
          <%= link_to "Log in", login_path,
                class: "text-gray-400 hover:text-white text-xs font-medium transition-colors" %>
          <%= link_to "Sign up", sign_up_path,
                class: "text-xs bg-green-700 hover:bg-green-600 text-white font-medium px-3 py-1 rounded transition-colors" %>
        </div>
      <% end %>
    </div>
    <%= yield %>
  </body>
</html>
