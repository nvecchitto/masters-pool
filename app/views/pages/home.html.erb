<% content_for :title, "Masters Pool" %>

<div class="min-h-screen bg-gray-950 text-gray-100">
  <header class="bg-green-900 border-b border-green-700 px-6 py-5">
    <h1 class="text-2xl font-bold text-white">Masters Pool</h1>
  </header>

  <main class="max-w-2xl mx-auto px-6 py-12 space-y-8">

    <%# Flash messages %>
    <% if notice.present? %>
      <p class="bg-green-900/50 border border-green-700 text-green-300 px-4 py-3 rounded-lg text-sm"><%= notice %></p>
    <% end %>
    <% if alert.present? %>
      <p class="bg-red-900/50 border border-red-700 text-red-300 px-4 py-3 rounded-lg text-sm"><%= alert %></p>
    <% end %>

    <%# ── My Pools ────────────────────────────────────────────────────── %>
    <% if @my_pools.any? %>
      <section>
        <h2 class="text-lg font-semibold text-gray-200 mb-4">My Pools</h2>
        <ul class="space-y-3">
          <% @my_pools.each do |pool| %>
            <li class="bg-gray-900 border border-gray-800 rounded-lg px-5 py-4">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <p class="font-medium text-white"><%= pool.name %></p>
                  <p class="text-sm text-gray-400"><%= pool.tournament.name %></p>
                  <p class="text-xs text-gray-500 mt-1">
                    <%= pool.teams.size %><% if pool.max_participants.present? %>/<%= pool.max_participants %><% end %> joined
                    &middot;
                    <% if pool.draft_status == "predraft" %>
                      <span class="text-yellow-400">Waiting for players</span>
                    <% elsif pool.draft_status == "drafting" %>
                      <span class="text-blue-400">Draft in progress</span>
                    <% else %>
                      <span class="text-green-400">Draft complete</span>
                    <% end %>
                  </p>
                </div>
                <div class="flex flex-col items-end gap-2 shrink-0">
                  <% if pool.draft_status == "predraft" %>
                    <% if logged_in? && current_user.id == pool.creator_id %>
                      <%= button_to "Start Draft",
                            start_draft_pool_path(pool),
                            class: "text-xs bg-green-700 hover:bg-green-600 text-white font-medium px-3 py-1.5 rounded transition-colors",
                            data: { turbo: false } %>
                    <% else %>
                      <span class="text-xs text-gray-500 italic">Waiting for creator to start…</span>
                    <% end %>
                  <% else %>
                    <div class="flex gap-3">
                      <%= link_to "Draft", pool_draft_path(pool),
                            class: "text-sm text-amber-400 hover:text-amber-300 font-medium transition-colors" %>
                      <%= link_to "Dashboard →", pool_dashboard_path(pool),
                            class: "text-sm text-green-400 hover:text-green-300 font-medium transition-colors" %>
                    </div>
                  <% end %>
                </div>
              </div>
              <%# Participants list %>
              <div class="mt-3 flex flex-wrap gap-2">
                <% pool.teams.each do |team| %>
                  <span class="text-xs bg-gray-800 border border-gray-700 text-gray-300 px-2 py-0.5 rounded-full">
                    <%= team.participant.name %>
                    <% if team.participant_id == pool.creator_id %>
                      <span class="text-yellow-500">★</span>
                    <% end %>
                  </span>
                <% end %>
                <% if pool.max_participants.present? && pool.teams.size < pool.max_participants %>
                  <% (pool.max_participants - pool.teams.size).times do %>
                    <span class="text-xs bg-gray-800/50 border border-dashed border-gray-700 text-gray-600 px-2 py-0.5 rounded-full">open slot</span>
                  <% end %>
                <% end %>
              </div>
            </li>
          <% end %>
        </ul>
      </section>
    <% end %>

    <%# ── Open Pools (joinable) ───────────────────────────────────────── %>
    <% if @open_pools.any? %>
      <section>
        <h2 class="text-lg font-semibold text-gray-200 mb-4">Open Pools</h2>
        <ul class="space-y-3">
          <% @open_pools.each do |pool| %>
            <li class="bg-gray-900 border border-gray-800 rounded-lg px-5 py-4 flex items-center justify-between gap-4">
              <div>
                <p class="font-medium text-white"><%= pool.name %></p>
                <p class="text-sm text-gray-400"><%= pool.tournament.name %></p>
                <p class="text-xs text-gray-500 mt-1">
                  <%= pool.teams.size %>/<%= pool.max_participants %> joined
                </p>
              </div>
              <% if logged_in? %>
                <%= button_to "Join Pool",
                      join_pool_path(pool),
                      class: "text-sm bg-green-700 hover:bg-green-600 text-white font-semibold px-4 py-2 rounded-lg transition-colors shrink-0",
                      data: { turbo: false } %>
              <% else %>
                <%= link_to "Log in to join", login_path,
                      class: "text-sm text-green-400 hover:text-green-300 font-medium shrink-0" %>
              <% end %>
            </li>
          <% end %>
        </ul>
      </section>
    <% end %>

    <%# ── Create a Pool ───────────────────────────────────────────────── %>
    <section class="bg-gray-900 border border-gray-800 rounded-xl p-6">
      <h2 class="text-base font-semibold text-gray-200 mb-5">Create a Pool</h2>

      <% unless logged_in? %>
        <div class="bg-yellow-900/30 border border-yellow-700 rounded-lg px-4 py-3 mb-5 flex items-center justify-between gap-4">
          <p class="text-yellow-300 text-sm">You must be logged in to create a pool.</p>
          <div class="flex gap-3 shrink-0">
            <%= link_to "Log in", login_path,
                  class: "text-xs bg-green-700 hover:bg-green-600 text-white font-medium px-3 py-1.5 rounded transition-colors" %>
            <%= link_to "Sign up", sign_up_path,
                  class: "text-xs text-green-400 hover:text-green-300 font-medium" %>
          </div>
        </div>
      <% end %>

      <% if @api_error %>
        <p class="text-sm text-red-400 bg-red-900/30 border border-red-800 rounded-lg px-4 py-3 mb-4">
          Could not reach Sportsdata.io — set <code class="bg-gray-800 px-1 rounded">SPORTSDATA_API_KEY</code> in your environment.
        </p>
      <% end %>

      <%= tag.form action: pools_path, method: :post, class: "space-y-5" do %>
        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
        <%= hidden_field_tag :sportsdata_id, "" %>
        <%= hidden_field_tag :tournament_name, "" %>
        <%= hidden_field_tag :total_rounds, "" %>

        <%# Tournament %>
        <div>
          <label class="block text-xs text-gray-400 mb-1">Tournament</label>
          <% if @api_tournaments.any? %>
            <%= select_tag :api_tournament,
                  options_for_select(
                    @api_tournaments.map { |t|
                      label  = t[:is_in_progress] ? "🟢 #{t[:name]}" : t[:name]
                      label += " — #{t[:location]}" if t[:location].present?
                      label += " (#{t[:start_date]})" if t[:start_date].present?
                      value  = "#{t[:sportsdata_id]}|#{t[:total_rounds]}|#{t[:name]}"
                      [label, value]
                    }
                  ),
                  prompt: "Select a tournament…",
                  id: "api_tournament_select",
                  class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:border-green-500 text-sm" %>
          <% else %>
            <p class="text-sm text-gray-500 italic">No tournaments available — check your API key.</p>
          <% end %>
        </div>

        <%# Pool name %>
        <div>
          <label class="block text-xs text-gray-400 mb-1">Pool name</label>
          <%= text_field_tag :pool_name, nil,
                placeholder: "e.g. Office Masters Pool",
                class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-white placeholder-gray-500 focus:outline-none focus:border-green-500 text-sm" %>
        </div>

        <%# Max participants %>
        <div>
          <label class="block text-xs text-gray-400 mb-1">Number of participants</label>
          <%= select_tag :max_participants,
                options_for_select((2..12).map { |n| [n, n] }, 4),
                class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:border-green-500 text-sm" %>
          <p class="text-xs text-gray-500 mt-1">You'll be added automatically. Others join from the home page.</p>
        </div>

        <%# Golfers per team %>
        <div>
          <label class="block text-xs text-gray-400 mb-1">Golfers per team</label>
          <%= select_tag :golfers_per_team,
                options_for_select((1..8).map { |n| [n, n] }, 5),
                class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:border-green-500 text-sm" %>
        </div>

        <%# Cut penalty %>
        <div>
          <label class="block text-xs text-gray-400 mb-1">Penalty per round after cut</label>
          <%= select_tag :cut_penalty,
                options_for_select(
                  (0..10).map { |n| [n == 0 ? "No penalty (0)" : "+#{n} strokes", n] },
                  4
                ),
                class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:border-green-500 text-sm" %>
          <p class="text-xs text-gray-500 mt-1">Added per unplayed round for golfers who miss the cut, WD, or DQ.</p>
        </div>

        <button type="submit"
                class="w-full bg-green-700 hover:bg-green-600 text-white font-semibold py-2 rounded-lg text-sm transition-colors">
          Create Pool
        </button>
      <% end %>
    </section>

  </main>
</div>

<script>
  <%# ── Tournament dropdown: unpack composite value into hidden fields ── %>
  <% if @api_tournaments.any? %>
    const sel = document.getElementById("api_tournament_select");
    function syncTournament() {
      if (!sel.value) return;
      const [id, rounds, ...nameParts] = sel.value.split("|");
      document.querySelector("input[name='sportsdata_id']").value = id;
      document.querySelector("input[name='total_rounds']").value = rounds;
      document.querySelector("input[name='tournament_name']").value = nameParts.join("|");
    }
    sel.addEventListener("change", syncTournament);
    syncTournament();
  <% end %>
</script>
