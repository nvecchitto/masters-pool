<% content_for :title, "Sign Up — Masters Pool" %>

<div class="min-h-screen bg-gray-950 text-gray-100 flex flex-col">
  <header class="bg-green-900 border-b border-green-700 px-6 py-5">
    <h1 class="text-2xl font-bold text-white">Masters Pool</h1>
  </header>

  <main class="flex-1 flex items-center justify-center px-4 py-12">
    <div class="w-full max-w-sm">
      <h2 class="text-2xl font-bold text-white text-center mb-2">Create Account</h2>
      <p class="text-center text-sm text-gray-400 mb-8">
        If you've been added to a pool, sign up with the same email.
      </p>

      <% if alert.present? %>
        <p class="bg-red-900/50 border border-red-700 text-red-300 px-4 py-3 rounded-lg text-sm mb-6"><%= alert %></p>
      <% end %>

      <%= tag.form action: sign_up_path, method: :post, class: "bg-gray-900 border border-gray-800 rounded-xl p-6 space-y-5" do %>
        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>

        <div>
          <label class="block text-xs text-gray-400 mb-1">Name</label>
          <%= text_field_tag :name, params[:name],
                autofocus: true,
                placeholder: "Your name",
                class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-white placeholder-gray-500 focus:outline-none focus:border-green-500 text-sm" %>
        </div>

        <div>
          <label class="block text-xs text-gray-400 mb-1">Email</label>
          <%= email_field_tag :email, params[:email],
                class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-white placeholder-gray-500 focus:outline-none focus:border-green-500 text-sm" %>
        </div>

        <div>
          <label class="block text-xs text-gray-400 mb-1">Password</label>
          <%= password_field_tag :password, nil,
                placeholder: "At least 6 characters",
                class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-white placeholder-gray-500 focus:outline-none focus:border-green-500 text-sm" %>
        </div>

        <div>
          <label class="block text-xs text-gray-400 mb-1">Confirm Password</label>
          <%= password_field_tag :password_confirmation, nil,
                class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-white placeholder-gray-500 focus:outline-none focus:border-green-500 text-sm" %>
        </div>

        <button type="submit"
                class="w-full bg-green-700 hover:bg-green-600 text-white font-semibold py-2 rounded-lg text-sm transition-colors">
          Create Account
        </button>
      <% end %>

      <p class="text-center text-sm text-gray-500 mt-6">
        Already have an account?
        <%= link_to "Log in", login_path, class: "text-green-400 hover:text-green-300 font-medium" %>
      </p>
    </div>
  </main>
</div>
